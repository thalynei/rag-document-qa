# OpenAI API 配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# 模型配置
LLM_MODEL=gpt-4o-mini

# 向量模型配置（质谱 embedding-3）
EMBEDDING_API_KEY=your-zhipu-api-key
