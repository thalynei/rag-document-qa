# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# 至少配置一个 Provider 的 API Key，系统会根据所选模型自动使用对应的 Key
# 如果只配置 OPENAI_API_KEY，其他 Provider 会回退使用此 Key（兼容模式）

# OpenAI（默认）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# DeepSeek（可选）
DEEPSEEK_API_KEY=

# 通义千问（可选）
QWEN_API_KEY=

# 智谱 GLM（可选）
ZHIPU_API_KEY=

# ─── 模型配置 ─────────────────────────────────────────────────────────────────
# 默认 LLM 模型（可在前端切换）
LLM_MODEL=gpt-4o-mini

# ─── Embedding 模型配置 ───────────────────────────────────────────────────────
# 默认使用智谱 embedding-3（独立于 LLM 的 API Key）
EMBEDDING_API_KEY=your-zhipu-api-key
EMBEDDING_API_BASE=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3

# ─── RAG 参数 ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4
TEMPERATURE=0.3
SIMILARITY_THRESHOLD=0.3
CHROMA_PERSIST_DIR=./chroma_db

# ─── 其他配置 ─────────────────────────────────────────────────────────────────
# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT 密钥（生产环境请更换）
JWT_SECRET_KEY=rag-qa-secret-key-change-in-production

# 数据库连接（默认 SQLite）
DATABASE_URL=sqlite:///./data/rag_qa.db
